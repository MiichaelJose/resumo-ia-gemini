{
  "manifest_version": 3,
  "name": "TicketBoost",
  "version": "1.0.0",
  "description": "Extensão que captura mensagens, otimiza com dados relevantes e agiliza a abertura de chamados com IA.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "https://web.digisac.com.br/*",
    "https://web.whatsapp.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "dist/src/popup.html",
    "default_icon": {
      "16": "icons/logo.svg",
      "48": "icons/logo.svg",
      "128": "icons/logo.svg"
    }
  },
  "icons": {
    "16": "icons/logo.svg",
    "48": "icons/logo.svg",
    "128": "icons/logo.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.digisac.com.br/*",
        "https://web.whatsapp.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
